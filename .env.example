APP_ENV=production
APP_BASE_URL=https://app.shazoride.com
API_BASE_URL=https://app.shazoride.com
DATABASE_URL=postgresql://postgres:password@localhost:5432/shazoride
JWT_SECRET=YOUR_JWT_SECRET
SESSION_SECRET=YOUR_SESSION_SECRET

DEFAULT_COUNTRY_CODE=92
DEFAULT_CITY=Karachi
DEFAULT_CURRENCY=PKR

OTP_PRIMARY_CHANNEL=whatsapp
OTP_FALLBACK_CHANNEL=email
OTP_ENABLE_SMS_FALLBACK=false
OTP_CODE_LENGTH=4
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

WHATSAPP_PROVIDER=evolution
EVOLUTION_API_BASE_URL=https://evo.visioninfinity.co
EVOLUTION_API_KEY=YOUR_EVOLUTION_API_KEY
EVOLUTION_INSTANCE_NAME=shazo
EVOLUTION_DEFAULT_COUNTRY_CODE=92

EMAIL_PROVIDER=smtp
EMAIL_FROM=hello@shazoride.com
EMAIL_FROM_NAME=Shazo Ride
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER
SMTP_PASS=YOUR_SMTP_PASSWORD

SMS_PROVIDER=mock
SMS_API_KEY=demo_sms_api_key
SMS_SENDER_ID=SHAZO

PAYMENT_MODE=manual
MANUAL_PAYMENT_ENABLED=true
ONLINE_PAYMENT_ENABLED=false

FREE_COMMISSION_ENABLED=true
FREE_COMMISSION_START_DATE=2026-06-01
FREE_COMMISSION_END_DATE=2026-12-31

MAPS_PROVIDER=google
MAPS_API_KEY=YOUR_FRONTEND_MAPS_KEY
GEOCODING_API_KEY=YOUR_BACKEND_GEOCODING_KEY

ENABLE_DEMO_CREDENTIALS=true
ENABLE_API_MONITOR=true
